# /etc/config/uhttpd — Web server config for LuCI and guest portal
# Deployed to /etc/config/uhttpd after variable substitution

config uhttpd 'main'
	list listen_http '%%LAN_IP%%:80'
	list listen_https '%%LAN_IP%%:443'
	option redirect_https '1'
	option home '/www'
	option rfc1918_filter '1'
	option max_requests '3'
	option max_connections '100'
	option cert '/etc/uhttpd.crt'
	option key '/etc/uhttpd.key'
	option cgi_prefix '/cgi-bin'
	list lua_prefix '/cgi-bin/luci=/usr/lib/lua/luci/sgi/uhttpd.lua'
	option script_timeout '60'
	option network_timeout '30'
	option http_keepalive '20'
	option tcp_keepalive '1'
	option ubus_prefix '/ubus'

config uhttpd 'guest'
	list listen_https '%%GUEST_IP%%:443'
	option home '/www-guest'
	option cgi_prefix '/cgi-bin'
	option max_requests '3'
	option max_connections '50'
	option script_timeout '30'
	option network_timeout '15'
	option redirect_https '0'
	option rfc1918_filter '0'
	option cert '/etc/acme/guest.owl.red_ecc/fullchain.cer'
	option key '/etc/acme/guest.owl.red_ecc/guest.owl.red.key'
