# /etc/config/wireless — Radio and WiFi interface config for D-Link DIR-885L
# Deployed to /etc/config/wireless after variable substitution

config wifi-device 'radio0'
	option type 'mac80211'
	option path '%%RADIO0_PATH%%'
	option band '2g'
	option channel 'auto'
	option htmode 'HT20'
	option country '%%COUNTRY_CODE%%'
	option disabled '0'

config wifi-device 'radio1'
	option type 'mac80211'
	option path '%%RADIO1_PATH%%'
	option band '5g'
	option channel 'auto'
	option htmode 'VHT80'
	option country '%%COUNTRY_CODE%%'
	option disabled '0'

config wifi-iface 'wifinet_lan_2g'
	option device 'radio0'
	option ifname 'lan24'
	option network 'lan'
	option mode 'ap'
	option ssid '%%LAN_SSID%%'
	option encryption 'psk2'
	option key '%%LAN_WIFI_KEY%%'

config wifi-iface 'wifinet_lan_5g'
	option device 'radio1'
	option ifname 'lan5'
	option network 'lan'
	option mode 'ap'
	option ssid '%%LAN_SSID%%'
	option encryption 'psk2'
	option key '%%LAN_WIFI_KEY%%'

config wifi-iface 'wifinet_guest_2g'
	option device 'radio0'
	option ifname 'guest24'
	option network 'guest'
	option mode 'ap'
	option ssid '%%GUEST_SSID%%'
	option encryption 'psk2'
	option key '%%GUEST_WIFI_KEY%%'
	option isolate '1'

# Note: 5GHz guest VAP removed — brcmfmac on BCM4366B only supports 1 VAP per
# 5GHz radio. The 5GHz slot is used by the LAN SSID. Guest runs on 2.4GHz only.

config wifi-iface 'wifinet_iot'
	option device 'radio0'
	option ifname 'iot24'
	option network 'iot'
	option mode 'ap'
	option ssid '%%IOT_SSID%%'
	option encryption 'psk2'
	option key '%%IOT_WIFI_KEY%%'
	option isolate '0'
