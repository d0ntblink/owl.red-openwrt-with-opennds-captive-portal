config opennds 'setup'
	option enabled '1'
	option debuglevel '1'
	option fwhook_enabled '1'
	option gatewayinterface 'br-guest'
	option gatewayname 'owl.red guest network'
	option enable_serial_number_suffix '0'
	option login_option_enabled '3'
	option themespec_path '/usr/lib/opennds/theme_owlred.sh'
	option statuspath '/usr/lib/opennds/client_params_owlred.sh'
	option max_page_size '65536'
	option gatewayfqdn 'guest.owl.red'
	option gatewayport '2050'
	option maxclients '250'
	option preauthidletimeout '30'
	option authidletimeout '120'
	option sessiontimeout '1440'
	option checkinterval '15'
