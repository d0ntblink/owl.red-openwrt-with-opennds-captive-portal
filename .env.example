# owl.red OpenWrt Provisioning — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.

# --- Router Connection ---
ROUTER_IP=
ROUTER_USER=root
ROUTER_PASS=

# --- System ---
HOSTNAME=WAP1
DOMAIN=owl.red
TIMEZONE=America/Edmonton
TZ_OFFSET=MST7MDT,M3.2.0,M11.1.0
COUNTRY_CODE=CA

# --- WiFi Networks ---
LAN_SSID=
LAN_WIFI_KEY=
GUEST_SSID=
GUEST_WIFI_KEY=
IOT_SSID=
IOT_WIFI_KEY=

# --- Cloudflare (optional — enables HTTPS via Let's Encrypt DNS-01) ---
# Create token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit for your domain zone
CF_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
